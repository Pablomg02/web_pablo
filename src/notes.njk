<h1>Notes</h1>

<p>Writing on topics I care about. Ordered by publication date and unedited after publishing unless explicitly noted, so they stay as close to the original as possible. Feel free to reach out if you want to discuss any of them.</p>

<hr>

{% set notes = collections.note | reverse %}
{% if notes.length %}
  <ul class="essay-list">
    {% for post in notes %}
      <li class="essay-list__item">
        <a href="{{ post.url | relativeUrl(page.url) }}">{{ post.data.title }}</a>
        {% if post.date %}
          <div class="essay-list__meta">
            <time datetime="{{ post.date | dateToFormat }}">{{ post.date | dateToFormat('dd-MM-yyyy') }}</time>
            {% if post.data.updated %}
              <span aria-hidden="true">|</span>
              <span>Last edited <time datetime="{{ post.data.updated | dateToFormat }}">{{ post.data.updated | dateToFormat('dd-MM-yyyy') }}</time></span>
            {% endif %}
          </div>
        {% endif %}
        {% if post.data.description %}
          <p class="essay-list__description">{{ post.data.description }}</p>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% else %}
  <p>No notes published yet.</p>
{% endif %}
