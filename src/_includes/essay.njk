---
layout: base.njk
---
{% set backUrl = backUrl or '/thoughts/' %}
{% set backLabel = backLabel or 'Thoughts' %}
<a class="notes-back-link" href="{{ backUrl | relativeUrl(page.url) }}">&lt;&lt; Back to {{ backLabel }}</a>

<article class="content essay">
  <header class="essay__header">
    <h1>{{ title }}</h1>
    {% set hasPdf = tags and 'notebook' in tags and (page.inputPath | inputPdfExists) %}
    {% if date or (topics and topics.length) or hasPdf %}
      <div class="essay__meta">
        {% if date %}
          <time class="essay__date" datetime="{{ date | dateToFormat }}">{{ date | dateToFormat('dd-MM-yyyy') }}</time>
        {% endif %}
        {% if updated %}
          <span class="essay__meta-separator" aria-hidden="true">|</span>
          <span class="essay__updated">Last edited <time datetime="{{ updated | dateToFormat }}">{{ updated | dateToFormat('dd-MM-yyyy') }}</time></span>
        {% endif %}
        {% if date or updated %}<span class="essay__meta-separator" aria-hidden="true">|</span>{% endif %}
        <a
          class="share-link"
          href="{{ page.url | absoluteUrl(site.url) | escape }}"
          rel="bookmark"
          data-share-link
          data-share-title="{{ title | escape }}"
          data-share-url="{{ page.url | absoluteUrl(site.url) | escape }}"
          aria-label="Share {{ title | escape }}"
        >Share</a>
        <span class="essay__share-separator essay__share-separator--linkedin" aria-hidden="true">|</span>
        <a
          class="linkedin-share-link"
          href="https://www.linkedin.com/sharing/share-offsite/?url={{ page.url | absoluteUrl(site.url) | urlEncode }}"
          target="_blank"
          rel="noopener noreferrer"
          title="Share on LinkedIn"
          aria-label="Share {{ title | escape }} on LinkedIn"
        >LinkedIn</a>
        <span class="essay__share-separator essay__share-separator--x" aria-hidden="true">|</span>
        <a
          class="x-share-link"
          href="https://twitter.com/intent/tweet?url={{ page.url | absoluteUrl(site.url) | urlEncode }}&amp;text={{ title | urlEncode }}"
          target="_blank"
          rel="noopener noreferrer"
          title="Share on X"
          aria-label="Share {{ title | escape }} on X"
        >X</a>
        {% if hasPdf %}
          {% set pdfUrl = (page.url | stripTrailingSlash) + '.pdf' %}
          <span class="essay__share-separator" aria-hidden="true">|</span>
          <a
            class="pdf-download-link"
            href="{{ pdfUrl | relativeUrl(page.url) }}"
            download
            title="Download as PDF"
            aria-label="Download {{ title | escape }} as PDF"
          >Download PDF</a>
        {% endif %}
      </div>
      {% if topics and topics.length %}
        <div class="essay__meta essay__meta--tags">
          <span class="essay-tags">
            {% for topic in topics %}<span class="essay-tag">{{ topic }}</span>{% endfor %}
          </span>
        </div>
      {% endif %}
    {% endif %}
  </header>
  {{ content | safe }}
</article>
