{% set seoTitle = metaTitle or (site.defaultTitle if page.url == '/' else title + ' | ' + site.name) %}
{% set seoDescription = description or site.defaultDescription %}
{% set canonicalUrl = page.url | absoluteUrl(site.url) %}
{% set robotsContent = robots or 'index, follow' %}
{% set socialImagePath = socialImage or site.socialImage %}
{% set socialImageUrl = socialImagePath | absoluteUrl(site.url) %}
<!DOCTYPE html>
<html lang="{{ site.locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seoTitle | escape }}</title>
  <meta name="description" content="{{ seoDescription | escape }}">
  <meta name="author" content="{{ site.author | escape }}">
  <meta name="robots" content="{{ robotsContent | escape }}">
  <link rel="canonical" href="{{ canonicalUrl | escape }}">
  <link rel="help" href="{{ '/llms.txt' | relativeUrl(page.url) }}">
  <link rel="icon" href="{{ site.favicon | relativeUrl(page.url) }}" type="image/svg+xml">
  <link rel="icon" href="{{ site.faviconPng | relativeUrl(page.url) }}" type="image/png" sizes="256x256">
  <link rel="apple-touch-icon" href="{{ site.faviconPng | relativeUrl(page.url) }}">
  <meta name="theme-color" content="#ffffff" id="theme-color-meta">
  <meta property="og:locale" content="{{ site.ogLocale | escape }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name | escape }}">
  <meta property="og:title" content="{{ seoTitle | escape }}">
  <meta property="og:description" content="{{ seoDescription | escape }}">
  <meta property="og:url" content="{{ canonicalUrl | escape }}">
  <meta property="og:image" content="{{ socialImageUrl | escape }}">
  <meta property="og:image:alt" content="{{ site.socialImageAlt | escape }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ seoTitle | escape }}">
  <meta name="twitter:description" content="{{ seoDescription | escape }}">
  <meta name="twitter:image" content="{{ socialImageUrl | escape }}">
  <meta name="twitter:image:alt" content="{{ site.socialImageAlt | escape }}">
  <meta name="twitter:creator" content="{{ site.twitterHandle | escape }}">
  <script>
    (function () {
      var storageKey = 'theme-preference';
      var root = document.documentElement;
      var themeMeta = document.getElementById('theme-color-meta');
      var mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

      function getAppliedTheme(preference) {
        if (preference === 'light' || preference === 'dark') {
          return preference;
        }

        return mediaQuery.matches ? 'dark' : 'light';
      }

      function applyTheme(preference) {
        var appliedTheme = getAppliedTheme(preference);

        if (preference === 'light' || preference === 'dark') {
          root.dataset.theme = preference;
        } else {
          delete root.dataset.theme;
        }

        if (themeMeta) {
          themeMeta.setAttribute('content', appliedTheme === 'dark' ? '#100f0c' : '#ffffff');
        }
      }

      var storedPreference = null;

      try {
        storedPreference = window.localStorage.getItem(storageKey);
      } catch (error) {
        storedPreference = null;
      }

      applyTheme(storedPreference);
      window.__applySiteTheme = applyTheme;
      window.__getAppliedSiteTheme = function () {
        return getAppliedTheme(storedPreference);
      };
      window.__getSiteTheme = function () {
        return storedPreference;
      };
      window.__setSiteTheme = function (preference) {
        storedPreference = preference;

        try {
          if (preference === 'light' || preference === 'dark') {
            window.localStorage.setItem(storageKey, preference);
          } else {
            window.localStorage.removeItem(storageKey);
          }
        } catch (error) {
          // Ignore storage write failures and still update the UI.
        }

        applyTheme(preference);
      };

      if (typeof mediaQuery.addEventListener === 'function') {
        mediaQuery.addEventListener('change', function () {
          if (!storedPreference) {
            applyTheme(null);
          }
        });
      }
    }());
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | relativeUrl(page.url) }}">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": {{ site.name | json | safe }},
      "jobTitle": {{ site.jobTitle | json | safe }},
      "url": {{ site.url | json | safe }},
      "description": {{ site.defaultDescription | json | safe }},
      "image": {{ socialImageUrl | json | safe }},
      "sameAs": {{ site.sameAs | json | safe }}
    }
  </script>
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <a class="site-brand" href="{{ '/' | relativeUrl(page.url) }}">{{ site.brand }}</a>
      <div class="site-header__actions">
        {% if navigation and navigation.length %}
          <nav class="site-nav" aria-label="Primary navigation">
            {% for entry in navigation %}
              <a
                href="{{ entry.url | relativeUrl(page.url) }}"
                class="site-nav__link{% if entry.url == '/notes/' %} site-nav__link--notes{% endif %}{% if entry.url == page.url %} is-active{% endif %}"
                {% if entry.url == page.url %}aria-current="page"{% endif %}
              >
                {{ entry.title }}
              </a>
            {% endfor %}
          </nav>
        {% endif %}
        <button class="theme-toggle" type="button" aria-label="Toggle colour theme">
          <svg class="theme-toggle__moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="theme-toggle__sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </div>
    </div>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <script>
    (function () {
      var toggle = document.querySelector('.theme-toggle');

      if (!toggle || typeof window.__setSiteTheme !== 'function') {
        return;
      }

      function getActiveTheme() {
        if (typeof window.__getAppliedSiteTheme === 'function') {
          return window.__getAppliedSiteTheme();
        }

        return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      }

      function getNextTheme() {
        return getActiveTheme() === 'dark' ? 'light' : 'dark';
      }

      function updateToggleLabel() {
        var activeTheme = getActiveTheme();
        var nextTheme = activeTheme === 'dark' ? 'light' : 'dark';
        toggle.setAttribute('aria-label', 'Switch to ' + nextTheme + ' mode');
        toggle.dataset.theme = activeTheme;
      }

      toggle.addEventListener('click', function () {
        window.__setSiteTheme(getNextTheme());
        updateToggleLabel();
      });

      updateToggleLabel();
    }());
  </script>
</body>
</html>
